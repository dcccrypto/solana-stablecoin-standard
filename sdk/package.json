{
  "name": "sss-token-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript SDK for the Solana Stablecoin Standard (SSS). Deploy, manage, and interact with SSS-1 and SSS-2 stablecoins programmatically.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "ts-mocha -p ./tsconfig.test.json -t 120000 'tests/**/*.test.ts'",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/mocha": "^10.0.0",
    "@types/chai": "^4.3.0",
    "chai": "^4.3.0",
    "mocha": "^10.0.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.6.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
