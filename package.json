{
  "name": "solana-stablecoin-standard",
  "version": "0.1.0",
  "description": "Modular stablecoin SDK for Solana with SSS-1 (Minimal) and SSS-2 (Compliant) presets",
  "private": true,
  "workspaces": [
    "sdk",
    "cli"
  ],
  "scripts": {
    "build": "yarn workspace @stbr/sss-token build && yarn workspace sss-token-cli build",
    "test": "anchor test",
    "test:sdk": "yarn workspace @stbr/sss-token test",
    "test:backend": "cd backend && cargo test",
    "lint": "yarn workspace @stbr/sss-token lint",
    "deploy:devnet": "bash scripts/deploy-devnet.sh",
    "smoke:devnet": "npx ts-node scripts/smoke-test-devnet.ts"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/sinon": "^21.0.0",
    "chai": "^4.3.6",
    "mocha": "^9.0.3",
    "sinon": "^21.0.3",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@orca-so/common-sdk": "^0.7.0",
    "@orca-so/whirlpools-sdk": "^0.20.0",
    "@raydium-io/raydium-sdk-v2": "^0.2.33-alpha",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "decimal.js": "^10.6.0"
  }
}
